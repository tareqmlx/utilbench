{
  "name": "utilbench",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ],
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bun run copy:pdfjs && bun run copy:ort && bunx --bun vite build && bun run generate:og && bun run generate:icons",
    "build:only": "bun run copy:pdfjs && bun run copy:ort && bunx --bun vite build",
    "copy:pdfjs": "bun run scripts/copy-pdfjs-assets.ts",
    "copy:ort": "bun run scripts/copy-ort-assets.ts",
    "postinstall": "bun run scripts/copy-pdfjs-assets.ts && bun run scripts/copy-ort-assets.ts",
    "generate:og": "bun run scripts/generate-og-image.ts",
    "generate:icons": "bun run scripts/generate-icons.ts",
    "generate:font": "bun run scripts/generate-font-subset.ts",
    "prerender": "bun run scripts/prerender.ts",
    "preview": "bun run build && wrangler dev",
    "check": "bunx @biomejs/biome check ./src",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --coverage",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@jsquash/avif": "^2.1.1",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/oxipng": "^2.3.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/webp": "^1.5.0",
    "@pdf-lib/standard-fonts": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "croner": "^10.0.1",
    "cronstrue": "^3.13.0",
    "diff": "^8.0.3",
    "dompurify": "^3.3.3",
    "fflate": "^0.8.2",
    "fuse.js": "^7.1.0",
    "gifenc": "^1.0.3",
    "js-yaml": "^4.1.1",
    "jsonc-parser": "^3.3.1",
    "lottie-web": "^5.13.0",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "next-themes": "^0.4.6",
    "onnxruntime-web": "^1.27.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "6.0.227",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.4.0",
    "sonner": "^2.0.7",
    "svgo": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "upng-js": "^2.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/vite-plugin": "^1.38.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^8.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^28.1.0",
    "puppeteer": "^24.39.0",
    "satori": "^0.25.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0",
    "wrangler": "^4.94.0"
  }
}
